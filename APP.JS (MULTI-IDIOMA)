let lang = 'ca';

function setLanguage(l) {
    lang = l;
    fetch(`${l}.json`)
        .then(r => r.json())
        .then(t => {
            document.querySelectorAll("[data-i18n]").forEach(el => {
                const key = el.getAttribute("data-i18n");
                el.innerHTML = t[key] || key;
            });
        });
}

setLanguage('ca');
