<!DOCTYPE html>
<html lang="ca">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chrysalis Cooperativa</title>
    <link rel="stylesheet" href="style.css">
    <script defer src="app.js"></script>
</head>

<body>

    <!-- HEADER -->
    <header>
        <img src="logo.png" alt="Chrysalis logo" class="logo">

        <nav id="menu">
            <a href="index.html" data-i18n="menu.inici">Inici</a>
            <a href="quisom.html" data-i18n="menu.quisom">Qui Som</a>
            <a href="serveis.html" data-i18n="menu.serveis">Serveis</a>
            <a href="eco.html" data-i18n="menu.eco">ECO A SU MEMORIA</a>
            <a href="blog.html" data-i18n="menu.blog">Blog</a>
            <a href="donacions.html" data-i18n="menu.donacions">Donacions</a>
            <a href="contacte.html" data-i18n="menu.contacte">Contacte</a>
        </nav>

        <div class="idiomes">
            <button onclick="setLanguage('ca')">CAT</button>
            <button onclick="setLanguage('es')">ES</button>
            <button onclick="setLanguage('en')">EN</button>
        </div>
    </header>

    <!-- HERO -->
    <section class="hero">
        <h1 data-i18n="hero.titol">Acompanyem dones racialitzades supervivents de violències masclistes</h1>
        <p data-i18n="hero.subtitol">Transformem cuidant. Cuidem transformant.</p>

        <div class="botons-hero">
            <a href="contacte.html" class="btn1" data-i18n="hero.necessito">Necessito ajuda</a>
            <a href="donacions.html" class="btn2" data-i18n="hero.colabora">Vull col·laborar</a>
        </div>
    </section>

    <!-- SERVEIS RESUM -->
    <section class="serveis-preview">
        <h2 data-i18n="serveis.titol">Què oferim</h2>

        <div class="cards">

            <div class="card">
                <h3 data-i18n="serveis.psico">Atenció psicològica</h3>
                <p data-i18n="serveis.psico_txt">Sessions individuals i grupals amb professionals especialitzades.</p>
            </div>

            <div class="card">
                <h3 data-i18n="serveis.juridic">Assessorament jurídic</h3>
                <p data-i18n="serveis.juridic_txt">Regularització, drets, violència masclista i estrangeria.</p>
            </div>

            <div class="card">
                <h3 data-i18n="serveis.social">Acompanyament social</h3>
                <p data-i18n="serveis.social_txt">Recursos, suport i xarxes comunitàries.</p>
            </div>

        </div>

        <a href="serveis.html" class="btn3" data-i18n="serveis.veure">Veure tots els serveis →</a>
    </section>

    <!-- ECO -->
    <section class="eco">
        <h2 data-i18n="eco.titol">ECO A SU MEMORIA</h2>
        <p data-i18n="eco.txt">Dignifiquem la memòria, visibilitzem les vides i denunciem la violència.</p>
        <a href="eco.html" class="btn2" data-i18n="eco.explorar">Explorar el projecte →</a>
    </section>

    <!-- BLOG -->
    <section class="blog-preview">
        <h2 data-i18n="blog.titol">Articles recents</h2>
        <p data-i18n="blog.txt">Reflexions, memòria, interseccionalitat i resistències.</p>
        <a href="blog.html" class="btn3" data-i18n="blog.veure">Anar al blog →</a>
    </section>

    <!-- FOOTER -->
    <footer>
        <p>© 2026 Chrysalis Cooperativa</p>
        <p data-i18n="footer.socials">Segueix-nos:</p>

        <div class="xarxes">
            <a href="https://instagram.com" target="_blank">Instagram</a>
            <a href="https://tiktok.com" target="_blank">TikTok</a>
            <a href="https://facebook.com" target="_blank">Facebook</a>
            <a href="https://spotify.com" target="_blank">Spotify</a>
        </div>
    </footer>

</body>
</html>
