body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #ffffff;
    color: #333;
}

header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px;
}

.logo {
    height: 70px;
}

nav a {
    margin: 0 15px;
    text-decoration: none;
    color: #000;
    font-weight: bold;
}

.idiomes button {
    margin-left: 10px;
    background: #f08bb4;
    border: none;
    padding: 6px 10px;
    cursor: pointer;
    border-radius: 5px;
}

/* HERO */
.hero {
    padding: 120px 40px;
    text-align: center;
    background: linear-gradient(135deg, #f8d7e6, #ffd6eb, #f5e8fa);
}

/* BOTONS */
.btn1, .btn2, .btn3 {
    padding: 12px 20px;
    text-decoration: none;
    border-radius: 8px;
    font-weight: bold;
}

.btn1 { background: #f08bb4; color: white; }
.btn2 { background: white; color: #f08bb4; border: 2px solid #f08bb4; }
.btn3 { display: inline-block; margin-top: 20px; }

/* SERVEIS */
.serveis-preview {
    padding: 60px;
    text-align: center;
}

.cards {
    display: flex;
    justify-content: center;
    gap: 20px;
}

.card {
    background: #fff;
    border: 2px solid #f08bb4;
    padding: 20px;
    width: 250px;
    border-radius: 10px;
}

/* ECO */
.eco {
    padding: 60px;
    text-align: center;
    background: #222;
    color: white;
}

/* BLOG */
.blog-preview {
    padding: 60px;
    text-align: center;
}

/* FOOTER */
footer {
    padding: 30px;
    background: #f0f0f0;
    text-align: center;
}
